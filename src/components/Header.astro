---
import { URL_BASE } from "@/config";

interface Props {
  abbott?: "white" | "black";
  bellanew?: "v1" | "v2";
}

const abbott = Astro.props.abbott || "black";
const bellanew = Astro.props.bellanew || "v1";
---

<header
  id="site-header"
  class="w-7xl mx-auto max-w-full p-4 md:p-6 relative"
  data-abbott={abbott}
  data-bellanew={bellanew}
>
  <div class="flex justify-between">
    <div>
      <a href={URL_BASE}>
        <img
          id="header-abbott-logo"
          class="w-32"
          src={`${URL_BASE}/logos/abbott_${abbott}.webp`}
          alt={`Logo Abbott ${abbott.charAt(0).toUpperCase() + abbott.slice(1)}`}
        />
      </a>
    </div>
    <div>
      <img
        id="header-bellanew-logo"
        class="w-44"
        src={`${URL_BASE}/logos/bellanew_${bellanew}.webp`}
        alt="Logo Bellanew"
      />
    </div>
  </div>

  <div
    class="absolute top-16 -right-2 lg:-right-8 xl:-right-12 transform -rotate-90"
  >
    <span class="text-sm text-white"></span>
  </div>
</header>
