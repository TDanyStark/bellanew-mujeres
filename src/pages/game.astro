---
import Header from "@/components/Header.astro";
import { URL_BASE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import GameApp from "@/components/GameApp.astro";
---

<Layout>
  <div
    id="game-bg"
    class="min-h-screen bg-right lg:bg-center lg:bg-cover transition-[background-image] duration-500"
    style={`background-image: url(${URL_BASE}/images/bg_home.webp);`}
  >
    <div class="min-h-screen flex-1 flex flex-col max-w-7xl mx-auto">
      <Header />
      <main class="flex-1">
        <GameApp />
      </main>
      <footer class="flex flex-col lg:flex-row justify-between items-end p-4 md:p-6">
        <div class="lg:w-1/2">
          <p class="text-xs text-purple-dark">
            MATERIAL EXCLUSIVO PARA EL CUERPO MÉDICO <strong>CO-26-0493</strong>
          </p>
        </div>

        <div class="lg:w-1/2 flex justify-end">
          <img
            class="h-8 object-contain"
            src={`${URL_BASE}/logos/logo_natural_purple.webp`}
            alt="Logo Abbott"
          />
        </div>
      </footer>
    </div>
  </div>
</Layout>
